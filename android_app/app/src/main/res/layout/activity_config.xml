<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- Title -->
        <TextView
            android:id="@+id/config_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SignSync Config"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:gravity="center" />

        <!-- Employee ID Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Employee ID"
            android:textColor="@color/light_gray"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/employee_id_input"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/input_background"
            android:textColor="@color/white"
            android:textColorHint="@color/dark_gray"
            android:hint="Enter Employee ID"
            android:textSize="14sp"
            android:padding="8dp"
            android:inputType="textNoSuggestions|textCapCharacters"
            android:maxLength="20"
            android:layout_marginBottom="12dp" />

        <!-- PIN Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PIN"
            android:textColor="@color/light_gray"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/pin_input"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/input_background"
            android:textColor="@color/white"
            android:textColorHint="@color/dark_gray"
            android:hint="Enter PIN"
            android:textSize="14sp"
            android:padding="8dp"
            android:inputType="numberPassword"
            android:maxLength="10"
            android:layout_marginBottom="12dp" />

        <!-- Server URL Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server URL"
            android:textColor="@color/light_gray"
            android:textSize="12sp"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/server_url_input"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="@drawable/input_background"
            android:textColor="@color/white"
            android:textColorHint="@color/dark_gray"
            android:hint="http://your-server.com/"
            android:textSize="12sp"
            android:padding="8dp"
            android:inputType="textUri"
            android:layout_marginBottom="16dp" />

        <!-- Settings Section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Settings"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <!-- Auto Start Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Auto-start monitoring"
                android:textColor="@color/light_gray"
                android:textSize="12sp" />

            <Switch
                android:id="@+id/auto_start_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:theme="@style/SwitchTheme" />

        </LinearLayout>

        <!-- Battery Optimization Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Battery optimization"
                android:textColor="@color/light_gray"
                android:textSize="12sp" />

            <Switch
                android:id="@+id/battery_optimization_switch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:theme="@style/SwitchTheme" />

        </LinearLayout>

        <!-- Status Text -->
        <TextView
            android:id="@+id/config_status_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Configure your settings"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:gravity="center"
            android:minHeight="60dp"
            android:padding="8dp"
            android:background="@drawable/status_background"
            android:layout_marginBottom="16dp" />

        <!-- Progress Bar -->
        <ProgressBar
            android:id="@+id/loading_progress"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Button Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Test Connection Button -->
            <Button
                android:id="@+id/test_connection_button"
                android:layout_width="140dp"
                android:layout_height="40dp"
                android:text="Test Connection"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:background="@drawable/button_test"
                android:layout_marginBottom="8dp" />

            <!-- Save Configuration Button -->
            <Button
                android:id="@+id/save_config_button"
                android:layout_width="140dp"
                android:layout_height="44dp"
                android:text="Save Config"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:background="@drawable/button_save"
                android:layout_marginBottom="8dp" />

            <!-- Reset Configuration Button -->
            <Button
                android:id="@+id/reset_config_button"
                android:layout_width="140dp"
                android:layout_height="36dp"
                android:text="Reset"
                android:textColor="@color/light_gray"
                android:textSize="10sp"
                android:background="@drawable/button_reset"
                android:layout_marginBottom="16dp" />

        </LinearLayout>

        <!-- Info Section -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enter your employee credentials to enable health monitoring and stress detection."
            android:textColor="@color/dark_gray"
            android:textSize="10sp"
            android:gravity="center"
            android:padding="8dp" />

    </LinearLayout>

</ScrollView>
