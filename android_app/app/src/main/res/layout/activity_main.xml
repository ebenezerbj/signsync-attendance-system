<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/black"
    android:gravity="center">

    <!-- App Title -->
    <TextView
        android:id="@+id/app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SignSync Health"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Status Text -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Initializing..."
        android:textColor="@color/light_gray"
        android:textSize="14sp"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Health Data Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="20dp">

        <!-- Heart Rate -->
        <TextView
            android:id="@+id/heart_rate_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Heart Rate: --"
            android:textColor="@color/health_red"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="center" />

        <!-- Stress Level -->
        <TextView
            android:id="@+id/stress_level_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stress Level: --"
            android:textColor="@color/health_orange"
            android:textSize="16sp"
            android:layout_marginBottom="8dp"
            android:layout_gravity="center" />

        <!-- Connection Status -->
        <TextView
            android:id="@+id/connection_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Server: Connecting..."
            android:textColor="@color/light_gray"
            android:textSize="12sp"
            android:layout_gravity="center" />

    </LinearLayout>

    <!-- Control Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <!-- Start Monitoring Button -->
        <Button
            android:id="@+id/start_monitoring_button"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:text="Start Monitor"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/button_start"
            android:layout_marginBottom="8dp" />

        <!-- Stop Monitoring Button -->
        <Button
            android:id="@+id/stop_monitoring_button"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:text="Stop Monitor"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:background="@drawable/button_stop"
            android:layout_marginBottom="8dp"
            android:visibility="gone" />

        <!-- Configuration Button -->
        <Button
            android:id="@+id/config_button"
            android:layout_width="140dp"
            android:layout_height="40dp"
            android:text="Settings"
            android:textColor="@color/light_gray"
            android:textSize="11sp"
            android:background="@drawable/button_config" />

    </LinearLayout>

</LinearLayout>
