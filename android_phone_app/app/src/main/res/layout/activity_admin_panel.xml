<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Admin Panel"
        android:textSize="24sp"
        android:gravity="center" />

    <TextView
        android:id="@+id/userNameText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Admin User"
        android:textSize="18sp"
        android:layout_marginTop="16dp" />

    <TextView
        android:id="@+id/userRoleText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Administrator"
        android:textSize="16sp" />

    <View
        android:id="@+id/adminStatusChip"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp" />

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize" />

    <!-- Simple card buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="24dp">

        <Button
            android:id="@+id/employeeManagementCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Employee Management"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/systemSettingsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="System Settings"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/reportsCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reports"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/scheduleManagementCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Schedule Management"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/securityAuditCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Security Audit"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/notificationCenterCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Notification Center"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/dataBackupCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Data Backup"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/systemMonitoringCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="System Monitoring"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/integrationManagementCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Integration Management" />

    </LinearLayout>

</LinearLayout>
