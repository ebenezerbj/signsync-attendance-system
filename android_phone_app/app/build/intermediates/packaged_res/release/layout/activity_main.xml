<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center">

    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SignSync Attendance System"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@android:id/text1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Comprehensive Android Phone App\n\nFeatures:\n• Employee Portal\n• Kiosk Mode\n• Clock In/Out Check Service\n• GPS Validation\n• Photo Capture\n• Admin Panel\n• Reports Generation"
        android:textSize="16sp"
        android:gravity="center"
        android:lineSpacingMultiplier="1.5" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="All PHP backend functionality has been successfully implemented as native Android components."
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="24dp"
        android:textStyle="italic" />

</LinearLayout>
